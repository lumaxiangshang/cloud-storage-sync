{
  "name": "pantools",
  "version": "2.0.0",
  "description": "PanTools - 企业级网盘管理工具，支持批量转存、多账号管理、资源监控",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json && electron dist/main/index.js",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "start": "node server.js",
    "setup": "npx playwright install chromium"
  },
  "keywords": [
    "electron",
    "cloud-storage",
    "baidu",
    "quark",
    "xunlei"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@playwright/browser-chromium": "^1.50.1",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "csv-parser": "^3.0.0",
    "electron-store": "^8.2.0",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "p-queue": "^6.6.2",
    "playwright": "^1.50.1",
    "uuid": "^10.0.0",
    "winston": "^3.14.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "28.3.3",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.cloudstorage.sync",
    "productName": "网盘转存工具",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.png"
    }
  }
}
